# ═══════════════════════════════════════════════════════════════════════════════
# NFC Data Ingestion Service — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in real values.
# In production, SECRET_KEY and ENCRYPTION_KEY MUST be strong random strings (32+ chars).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=plain                 # structured (JSON) | plain (human-readable)

# ── Security (REQUIRED — change before deploying) ─────────────────────────────
SECRET_KEY=your-secret-key-here-min-32-chars
ENCRYPTION_KEY=your-encryption-key-here-min-32-chars

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ingestion_service
DB_POOL_SIZE=20                  # Base connection pool size
DB_MAX_OVERFLOW=50               # Max additional connections under load
DB_POOL_TIMEOUT=30               # Seconds to wait for a connection
DB_POOL_RECYCLE=3600             # Recycle connections after N seconds

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# ── External Services ─────────────────────────────────────────────────────────
OPENAI_API_KEY=                  # Optional — stub analysis if empty

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Ingestion Limits ──────────────────────────────────────────────────────────
MAX_CSV_SIZE_MB=50               # Maximum upload size
INGESTION_CHUNK_SIZE=5000        # Rows per bulk insert batch
MAX_CONCURRENT_INGESTIONS=10     # Limit parallel ingestions

# ── Audit Log ─────────────────────────────────────────────────────────────────
AUDIT_RETENTION_DAYS=365         # Days before archival
AUDIT_PARTITION_INTERVAL=monthly # monthly | quarterly

# ── Admin Tool Connections ────────────────────────────────────────────────────
# These define which saved DB connections are used by admin tools (Associate Lookup,
# Client Onboarding, Email Discrepancy Audit). Set to your target hosts.
NFC_PROD_HOST=your-prod-db-host.example.com
NFC_PROD_PORT=5432
NFC_PROD_DB=your_prod_db
LOOKUP_HOST=your-sybase-host.example.com
LOOKUP_PORT=2125
LOOKUP_DB=YourDatabase
